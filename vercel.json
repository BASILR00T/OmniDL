{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/extract.ts": {
      "maxDuration": 60
    },
    "api/download.ts": {
      "maxDuration": 60
    }
  }
}
